# AWS Bedrock Configuration
# Bedrock model ID for agent orchestration and summarization
BEDROCK_MODEL=us.anthropic.claude-sonnet-4-20250514-v1:0

# AWS region for Bedrock and S3
AWS_REGION=us-east-1

# Maximum tokens for LLM summary generation
LLM_MAX_TOKENS=500

# S3 Storage Configuration
# S3 bucket name for storing meeting notes and session state
S3_BUCKET_NAME=summitassistant-demo-bucket

# AWS region for S3 bucket
S3_REGION=us-east-1

# S3 endpoint URL (for local development with LocalStack/MinIO)
# Comment out for production EKS deployment
S3_ENDPOINT_URL=http://localhost:4566

# MCP Server Configuration
# Model Context Protocol server URL for Google Calendar integration
MCP_SERVER_URL=http://mcp-server:8080

# Weather Agent Configuration (for agent-to-agent communication)
# URL for the Weather Agent service
WEATHER_AGENT_URL=http://strands-weather-agent/agent

# Agent Configuration
# Session timeout in seconds
SESSION_TIMEOUT=3600

# Maximum retries for external service calls
MAX_RETRIES=3

# Base delay for exponential backoff (seconds)
RETRY_BASE_DELAY=1.0

# AWS Credentials (for local development)
# In EKS, use IAM Roles for Service Accounts (IRSA) instead
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
